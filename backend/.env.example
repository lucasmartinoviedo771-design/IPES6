DJANGO_ENV=production
DEBUG=False
SECRET_KEY=generate-your-secret-key-here
DB_NAME=ipes6
DB_USER=ipes_user
DB_PASSWORD=your-db-password
DB_ROOT_PASSWORD=your-root-password
